

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATIONS_MANAGER
  DESIGNER
  SUPERVISOR
  WORKER
  CUSTOMER
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ProductionStatus {
  QUEUED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

// ────────────────────────────────────────────────
// MASTER DATA
// ────────────────────────────────────────────────

model states {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  code String @unique
  name String @unique

  cities cities[]
}

model cities {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  stateId String @db.ObjectId
  name    String

  state states  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  areas areas[]
}

model areas {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  cityId  String  @db.ObjectId
  name    String
  pincode String?

  city      cities              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  addresses customer_address[]
}

// ────────────────────────────────────────────────
// UNITS OF MEASUREMENT (now a table)
// ────────────────────────────────────────────────

model uom {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  code       String  @unique // METER, KG, PIECE, ROLL, CONE, PACK, etc.
  name       String // Meter, Kilogram, Piece, Roll, Cone, Pack
  symbol     String? // m, kg, pc, roll, cone
  category   String? // LENGTH, WEIGHT, COUNT, AREA, VOLUME
  baseFactor Float? // for conversions (e.g. 1 METER → 100 if base is cm)
  isActive   Boolean @default(true)

  // rawMaterials RawMaterial[]
}

// ────────────────────────────────────────────────
// USERS
// ────────────────────────────────────────────────

model users {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  mobile   String  @unique
  email    String? @unique
  username String  @unique
  password String // hashed
  role     Role

  // productions     Production[]
  // productionLogs  ProductionLog[]
  // issuedMaterials RawMaterialIssued[] @relation("IssuedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ────────────────────────────────────────────────
// CUSTOMERS
// ────────────────────────────────────────────────

model customers {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  mobile    String   @unique
  email     String?  @unique

  addresses customer_address[]
  // orders    Order[]   // if you plan to link orders later

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model customer_address {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String @db.ObjectId
  areaId      String @db.ObjectId
  addressLine String
  landmark    String?
  pincode     String
  isDefault   Boolean @default(false)

  customer customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  area     areas     @relation(fields: [areaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


